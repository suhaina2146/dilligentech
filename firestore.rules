rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isMember(pairId) {
      return signedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(pairId)).data.memberUids;
    }

    // One-time pairing codes used only during first-time setup on each device.
    match /pairings/{code} {
      allow create: if signedIn()
        && request.resource.data.creatorUid == request.auth.uid
        && request.resource.data.status == 'pending';

      // Anyone signed in can read a code to attempt a claim (they must know the code).
      allow read: if signedIn();

      // Claiming: only allowed to flip pending -> claimed, and only by someone
      // who is not the original creator.
      allow update: if signedIn()
        && resource.data.status == 'pending'
        && request.resource.data.status == 'claimed'
        && request.resource.data.creatorUid == resource.data.creatorUid
        && request.auth.uid != resource.data.creatorUid;

      allow delete: if false;
    }

    // Per-device profile: fcm token, role, which conversation it belongs to.
    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if signedIn() && request.auth.uid == uid;
    }

    // The shared private space. Only the two paired uids may touch anything inside.
    match /conversations/{pairId} {
      allow read: if isMember(pairId);
      allow create: if signedIn() && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.memberUids.size() == 2;
      allow update, delete: if false;

      match /messages/{msgId} {
        allow read: if isMember(pairId);
        allow create: if isMember(pairId) && request.resource.data.senderId == request.auth.uid;
        allow update: if isMember(pairId); // allows marking read
        allow delete: if false;
      }

      match /worksheet/{taskId} {
        allow read, create, update: if isMember(pairId);
        allow delete: if isMember(pairId);
      }

      match /attendance/{uid} {
        allow read: if isMember(pairId);
        allow write: if isMember(pairId) && request.auth.uid == uid;
      }
    }
  }
}
